{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "watch .ts .md etc",
            "type": "shell",
            "command": "npm",
            "args": ["run", "prettier:watch"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "isBackground": true,
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            },
            "problemMatcher": []
        },
        {
            "label": "watch .cpp",
            "type": "shell",
            "command": "npm",
            "args": ["run", "clang-format:watch"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "isBackground": true,
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            },
            "problemMatcher": []
        },
        {
            "label": "watch .py",
            "type": "shell",
            "command": "npm",
            "args": ["run", "black:watch"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "isBackground": true,
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            },
            "problemMatcher": []
        },
        {
            "label": "format: 02-sliding-window (C#)",
            "type": "process",
            "command": "dotnet",
            "args": [
                "format",
                "${workspaceFolder}\\src\\learn-topic-wise\\02-sliding-window\\sliding-window.csproj"
            ]
        },
        {
            "label": "build: 02-sliding-window (C#)",
            "type": "process",
            "command": "dotnet",
            "args": [
                "build",
                "${workspaceFolder}\\src\\learn-topic-wise\\02-sliding-window\\sliding-window.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary"
            ],
            "problemMatcher": "$msCompile",
            "dependsOn": ["format: 02-sliding-window (C#)"],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Configure: 02-sliding-window (C++)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S",
                "${workspaceFolder}/src/learn-topic-wise/02-sliding-window/",
                "-B",
                "${workspaceFolder}/src/learn-topic-wise/02-sliding-window/cpp-build/",
                "-G",
                "MinGW Makefiles"
            ]
        },
        {
            "label": "build: 02-sliding-window (C++)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "${workspaceFolder}/src/learn-topic-wise/02-sliding-window/cpp-build/"
            ],
            "dependsOn": ["Configure: 02-sliding-window (C++)"],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "format: 03-binary-search (C#)",
            "type": "process",
            "command": "dotnet",
            "args": [
                "format",
                "${workspaceFolder}\\src\\learn-topic-wise\\03-binary-search\\binary-search.csproj"
            ]
        },
        {
            "label": "build: 03-binary-search (C#)",
            "type": "process",
            "command": "dotnet",
            "args": [
                "build",
                "${workspaceFolder}\\src\\learn-topic-wise\\03-binary-search\\binary-search.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary"
            ],
            "problemMatcher": "$msCompile",
            "dependsOn": ["format: 03-binary-search (C#)"],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Configure: 03-binary-search (C++)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S",
                "${workspaceFolder}/src/learn-topic-wise/03-binary-search/",
                "-B",
                "${workspaceFolder}/src/learn-topic-wise/03-binary-search/cpp-build/",
                "-G",
                "MinGW Makefiles"
            ]
        },
        {
            "label": "build: 03-binary-search (C++)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "${workspaceFolder}/src/learn-topic-wise/03-binary-search/cpp-build/"
            ],
            "dependsOn": ["Configure: 03-binary-search (C++)"],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}
